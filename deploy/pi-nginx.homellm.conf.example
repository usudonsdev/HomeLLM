# /etc/nginx/sites-available/homellm  (example for Raspberry Pi)
# Static UI only. Do not proxy multi-GB video uploads through the Pi.
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    root /var/www/homellm;
    index index.html;

    # Next.js `output: "export"` + trailingSlash creates /videos/index.html etc.
    # Prefer index.html before falling through as a bare directory (avoids 403).
    location / {
        try_files $uri $uri/index.html $uri/ =404;
    }
}
